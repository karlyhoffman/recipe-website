NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_ANON_KEY=""
ANTHROPIC_API_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Kroger Developer API (free tier) — used by the grocery price sync.
# Register an app at https://developer.kroger.com/ ("Public" type) with scope
# product.compact, then paste the credentials here.
KROGER_CLIENT_ID=""
KROGER_CLIENT_SECRET=""

# Admin authentication
# Generate ADMIN_PASSWORD_HASH: node -e "const b = require('bcryptjs'); console.log(b.hashSync('your-password', 12));"
# IMPORTANT: escape every $ in the hash with \$ or dotenv-expand will corrupt it
# Example: $2b$12$abc... → \$2b\$12\$abc...
# Generate JWT_SECRET: openssl rand -base64 32
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=
JWT_SECRET=